{
  "family": "prod-chatbot-be",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::476114133766:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::476114133766:role/ecsTaskExecutionRole",

  "containerDefinitions": [
    {
      "name": "chatbot-be-cont",
      "image": "476114133766.dkr.ecr.eu-west-2.amazonaws.com/prod-chatbot-be:latest",
      "cpu": 0,
      "essential": true,

      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "name": "chatbot-be-cont-8000-tcp"
        }
      ],

      "mountPoints": [],
      "volumesFrom": [],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/prod-chatbot-be",
          "awslogs-create-group": "true",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },

      "systemControls": []
    }
  ],

  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
