# EdPsych AI — Environment Variables Template
# ======================================
# Copy this file to .env and fill in your values.

# ==================== DATABASE ====================
DATABASE_URL=postgresql://edpsych:edpsych_secure_password@localhost:5432/edpsych_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=edpsych
DATABASE_PASSWORD=edpsych_secure_password
DATABASE_NAME=edpsych_db

# ==================== AWS S3 (object storage) ====================
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=eu-west-2
S3_BUCKET_IQ_TESTS=your-bucket-name
S3_BUCKET_REPORTS=your-bucket-name
S3_BUCKET_TEMP=your-bucket-name
# Optional — only set for custom endpoints (e.g. VPC endpoint).
S3_ENDPOINT_URL=

# ==================== OPENAI (Cloud LLM — active for report generation) ====================
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
USE_OPENAI=true

# ==================== GROQ (Cloud LLM — reserved for future chat flow) ====================
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
USE_GROQ=false

# ==================== TESSERACT OCR ====================
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_LANG=eng

# ==================== BACKEND (FastAPI) ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
DEBUG_MODE=true

# ==================== JWT AUTHENTICATION ====================
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MAGIC_LINK_EXPIRY_HOURS=48

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== FRONTEND (Next.js) ====================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=EdPsych AI
NEXT_PUBLIC_APP_VERSION=1.0.0
FRONTEND_URL=http://localhost:3000

# ==================== EMAIL (Brevo) ====================
BREVO_API_KEY=
EMAIL_FROM_NAME=The EdPsych Practice
EMAIL_FROM_ADDRESS=noreply@edpsych.com

# ==================== FILE UPLOAD LIMITS ====================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg

# ==================== AI GENERATION ====================
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000
AI_RETRY_ATTEMPTS=3

# ==================== REPORT GENERATION ====================
REPORT_LANGUAGE=en-GB
REPORT_FONT_SIZE=11
REPORT_PAGE_SIZE=A4
