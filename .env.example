# EdPsych AI - Environment Variables Template
# Copy this file to .env and update with your values

# ==================== DATABASE ====================
DATABASE_URL=postgresql://edpsych:edpsych_secure_password@localhost:5432/edpsych_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=edpsych
DATABASE_PASSWORD=edpsych_secure_password
DATABASE_NAME=edpsych_db

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== MINIO (S3 Alternative) ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
MINIO_BUCKET_IQ_TESTS=iq-tests
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_TEMP=temp

# ==================== OLLAMA (Local LLM) ====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
USE_LOCAL_LLM=true

# ==================== TESSERACT OCR ====================
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_LANG=eng

# ==================== BACKEND (FastAPI) ====================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
DEBUG_MODE=true

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== FRONTEND (Next.js) ====================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=EdPsych AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# ==================== FILE UPLOAD LIMITS ====================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg

# ==================== AI GENERATION ====================
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000
AI_RETRY_ATTEMPTS=3

# ==================== REPORT GENERATION ====================
REPORT_LANGUAGE=en-GB
REPORT_FONT_SIZE=11
REPORT_PAGE_SIZE=A4
