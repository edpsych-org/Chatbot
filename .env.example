# EdPsych AI — Environment Variable Template
# ============================================
# Copy to .env (local dev) or set these as container env vars on AWS.
# On AWS we recommend: Secrets Manager for *_API_KEY / *_PASSWORD / SECRET_KEY,
# Parameter Store (SSM) for everything else. Never commit real values.


# ---- DATABASE ---------------------------------------------------------
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Local:   postgresql+asyncpg://edpsych:edpsych_secure_password@localhost:5432/edpsych_db
# AWS RDS: postgresql+asyncpg://<user>:<pass>@<rds-endpoint>:5432/edpsych_db
DATABASE_URL=


# ---- LLM PROVIDERS ----------------------------------------------------
# OpenAI powers report-generation agents. Groq powers chat acknowledgements.
USE_OPENAI=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

USE_GROQ=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1


# ---- AWS S3 (object storage) -----------------------------------------
# On AWS, prefer an IAM role on the task/instance over access keys.
# When role-based auth is configured, leave ACCESS_KEY_ID / SECRET_ACCESS_KEY blank.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
S3_BUCKET_IQ_TESTS=
S3_BUCKET_REPORTS=
S3_BUCKET_TEMP=
S3_ENDPOINT_URL=


# ---- AUTH / JWT -------------------------------------------------------
# Generate per environment: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotating invalidates every JWT in flight — users will need to re-login.
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MAGIC_LINK_EXPIRY_HOURS=48


# ---- EMAIL (Brevo transactional API) ---------------------------------
BREVO_API_KEY=
EMAIL_FROM_NAME=The EdPsych Practice
EMAIL_FROM_ADDRESS=noreply@edpsych.com


# ---- APP RUNTIME ------------------------------------------------------
# prod: BACKEND_RELOAD=false, DEBUG_MODE=false, LOG_LEVEL=INFO
LOG_LEVEL=INFO
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false
DEBUG_MODE=false
FRONTEND_URL=
# Comma-separated; must include the deployed frontend origin.
CORS_ORIGINS=


# ---- OCR / FILE PIPELINE ---------------------------------------------
# Linux container: /usr/bin/tesseract. Windows dev: C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANG=eng
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg


# ---- REPORT / AI TUNING ----------------------------------------------
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000
AI_RETRY_ATTEMPTS=3
REPORT_LANGUAGE=en-GB
REPORT_FONT_SIZE=11
REPORT_PAGE_SIZE=A4
