# syntax=docker/dockerfile:1.6
# ---- EdPsych Backend — built from the PROJECT ROOT --------------------
# Build:  docker build -f Dockerfile-be -t chatbot-be:latest .
#
# The sibling backend/Dockerfile is built from ./backend as its context.
# This file exists to support a root-context build (useful on AWS
# CodeBuild / GitHub Actions where the whole repo is the build input).
# Paths below are relative to the project root — the .dockerignore next
# to this file must filter frontend/, node_modules/, .git/, .env, etc.,
# or the build context will be enormous.

FROM python:3.11-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# ---- System deps (OCR + Postgres client libs + tini as PID 1) ----
RUN apt-get update && apt-get install -y --no-install-recommends \
        tesseract-ocr \
        poppler-utils \
        libpq5 \
        tini \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ---- Install Python deps (cached layer — only re-runs when requirements change) ----
COPY backend/requirements-deploy.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# ---- Copy backend source only ----
# Secrets never enter the image — see .dockerignore. Real values come from:
#   1. docker-compose `env_file: .env` (local dev)
#   2. ECS task-def env vars sourced from AWS Secrets Manager / SSM (prod)
#   3. `docker run --env-file .env`  (one-off)
COPY backend/ .

# ---- Build-time smoke check (dummy envs, scoped to this RUN only) ----
RUN set -e; \
    export DATABASE_URL=postgresql+asyncpg://build:build@localhost:5432/build; \
    export SECRET_KEY=build-time-only-do-not-use-in-production-min-32-chars; \
    export CORS_ORIGINS=http://localhost:3000; \
    export FRONTEND_URL=http://localhost:3000; \
    python -m compileall -q app main.py; \
    python -c "import main; print('main import OK')"

# ---- Runtime user ----
RUN useradd --system --uid 1001 --home-dir /app --shell /usr/sbin/nologin edpsych \
    && mkdir -p /app/logs \
    && chown -R edpsych:edpsych /app

USER edpsych
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD python -c "import urllib.request, sys; \
sys.exit(0) if urllib.request.urlopen('http://127.0.0.1:8000/health', timeout=3).status == 200 else sys.exit(1)"

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"]
