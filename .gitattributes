# Treat PDFs as binary so git does not touch their line endings
*.pdf binary

# Text files always use LF on checkout, regardless of platform
*.py text eol=lf
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
Dockerfile text eol=lf
